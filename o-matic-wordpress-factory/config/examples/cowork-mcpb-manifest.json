{
  "name": "o-matic-wordpress-connector",
  "display_name": "O-Matic WordPress Connector",
  "version": "0.1.0",
  "description": "Configurable WordPress MCP connector for O-Matic website work.",
  "entrypoint": {
    "type": "stdio",
    "command": "node",
    "args": [
      "${MCPB_PLUGIN_ROOT}/server/index.mjs"
    ],
    "env": {
      "OMATIC_PROJECT_ROOT": "${MCPB_PROJECT_ROOT}",
      "OMATIC_WORDPRESS_FACTORY_CONFIG": "${OMATIC_WORDPRESS_FACTORY_CONFIG}",
      "OMATIC_WORDPRESS_FACTORY_PROFILE": "default",
      "OMATIC_WP_URL": "${OMATIC_WP_URL}",
      "OMATIC_WP_USERNAME": "${OMATIC_WP_USERNAME}",
      "OMATIC_WP_APP_PASSWORD": "${OMATIC_WP_APP_PASSWORD}",
      "OMATIC_WP_MCP_PATH": "${OMATIC_WP_MCP_PATH}",
      "OMATIC_WP_REST_API_ROOT": "${OMATIC_WP_REST_API_ROOT}",
      "OMATIC_WP_TIMEOUT_MS": "${OMATIC_WP_TIMEOUT_MS}",
      "MCP_PROTOCOL_VERSION": "2025-06-18"
    }
  }
}
