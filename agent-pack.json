{
  "schema": "lucidit-agent-pack-v1",
  "name": "o-matic-consulting-pack",
  "display_name": "O-Matic Consulting Pack",
  "owner": {
    "name": "lucidIT-LLC",
    "url": "https://github.com/lucidIT-LLC"
  },
  "homepage": "https://o-matic.io",
  "repository": "https://github.com/lucidIT-LLC/o-matic-consulting-pack",
  "license": "MIT",
  "description": "Host-neutral expert AI skills for critique, writing coaching, tool optimization, and evaluation.",
  "canonical_format": {
    "type": "markdown_skill",
    "entry_file": "SKILL.md",
    "frontmatter": "yaml",
    "body": "markdown_system_prompt",
    "contract": "The SKILL.md body is the canonical prompt contract. Host adapters must not fork behavior, voice, lane discipline, or task contracts.",
    "helper_scripts": {
      "print_system_prompt": "scripts/print-system-prompt.mjs",
      "build_ollama_modelfile": "scripts/build-ollama-modelfile.mjs",
      "sync_bundled_skills": "scripts/sync-bundled-skills.mjs",
      "sync_shared_skills": "scripts/sync-shared-skills.mjs",
      "audit_installed_skill_duplicates": "scripts/audit-installed-skill-duplicates.mjs"
    }
  },
  "adapters": {
    "claude": {
      "marketplace": ".claude-plugin/marketplace.json",
      "plugin_manifest": ".claude-plugin/plugin.json",
      "notes": "Claude marketplace/plugin metadata. Skills remain Markdown."
    },
    "codex": {
      "marketplace": ".agents/plugins/marketplace.json",
      "plugin_manifest": ".codex-plugin/plugin.json",
      "notes": "Codex plugin metadata plus skills/ directory. The root .agents/skills directory is a copy-friendly adapter for project-local Codex use."
    },
    "google": {
      "type": "system_instruction",
      "notes": "Use the selected SKILL.md body as the model system instruction in Gemini/Google AI Studio/Gems. Preserve trigger, voice, lane, and output-contract sections. scripts/print-system-prompt.mjs emits the canonical prompt."
    },
    "ollama": {
      "type": "modelfile_system_prompt",
      "notes": "Build a Modelfile by placing the selected SKILL.md body in the SYSTEM block. Choose the base model separately per deployment. scripts/build-ollama-modelfile.mjs emits a ready Modelfile."
    },
    "generic": {
      "type": "system_prompt",
      "notes": "For any chat runtime, pass the selected SKILL.md body as the system/developer instruction and supply the user's task as the first user message."
    }
  },
  "agents": [
